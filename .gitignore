# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files

# --- Compiled output & Angular ---
/dist
/tmp
/out-tsc
/bazel-out
/.angular/
*.tsbuildinfo

# --- Node ---
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# --- Tooling caches ---
.eslintcache
.prettiercache
*.log
*storybook.log

# --- Storybook ---
storybook-static/

# --- Tests & coverage ---
/coverage
*.lcov
.nyc_output

# --- Environment & secrets (never commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# --- IDEs and editors ---
.idea/
*.iml
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-project
*.sublime-workspace
.fleet/

# --- Visual Studio Code ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/*

# --- Miscellaneous (legacy / tooling) ---
.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# --- System files ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
